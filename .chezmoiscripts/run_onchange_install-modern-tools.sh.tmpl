#!/bin/bash
set -e

echo "📥 Installing modern tools from GitHub..."

# Detect OS and Architecture
OS="{{ .chezmoi.os }}"
ARCH="{{ .chezmoi.arch }}"

# Map chezmoi arch to common binary arch names
case "$ARCH" in
    amd64)
        BINARY_ARCH="x86_64"
        ;;
    arm64)
        BINARY_ARCH="aarch64"
        ;;
    *)
        BINARY_ARCH="$ARCH"
        ;;
esac

INSTALL_DIR="${HOME}/.local/bin"
mkdir -p "$INSTALL_DIR"

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Function to retry downloading and installing a tool
install_github_binary() {
    local tool_name="$1"
    local github_repo="$2"
    local binary_name="$3"
    local asset_pattern="$4"
    local max_retries=3
    local retry_count=0

    echo -e "\n${YELLOW}Installing ${tool_name}...${NC}"

    while [ $retry_count -lt $max_retries ]; do
        if download_and_install_binary "$tool_name" "$github_repo" "$binary_name" "$asset_pattern"; then
            echo -e "${GREEN}✓ ${tool_name} installed successfully${NC}"
            return 0
        fi
        
        retry_count=$((retry_count + 1))
        if [ $retry_count -lt $max_retries ]; then
            echo -e "${YELLOW}Retry ${retry_count}/${max_retries}...${NC}"
            sleep 2
        fi
    done

    echo -e "${RED}✗ Failed to install ${tool_name} after ${max_retries} attempts${NC}"
    return 1
}

# Function to download and install a binary
download_and_install_binary() {
    local tool_name="$1"
    local github_repo="$2"
    local binary_name="$3"
    local asset_pattern="$4"

    # Get latest release download URL
    local latest_release
    latest_release=$(curl -s "https://api.github.com/repos/${github_repo}/releases/latest" | grep "browser_download_url" | grep -E "$asset_pattern" | head -n 1 | cut -d '"' -f 4)

    if [ -z "$latest_release" ]; then
        echo "  ⚠️  Could not find release for ${tool_name}"
        return 1
    fi

    echo "  📦 Downloading from: $latest_release"
    
    local temp_dir
    temp_dir=$(mktemp -d)
    trap "rm -rf $temp_dir" EXIT

    # Download the file
    if ! curl -fsSL -o "${temp_dir}/download" "$latest_release"; then
        echo "  ⚠️  Failed to download ${tool_name}"
        return 1
    fi

    # Extract if it's a tar/zip file
    if file "${temp_dir}/download" | grep -q "gzip"; then
        tar -xzf "${temp_dir}/download" -C "$temp_dir"
    elif file "${temp_dir}/download" | grep -q "Zip"; then
        unzip -q "${temp_dir}/download" -d "$temp_dir"
    fi

    # Find and copy the binary
    local binary_path
    binary_path=$(find "$temp_dir" -type f -executable -name "$binary_name" 2>/dev/null | head -n 1)
    
    if [ -z "$binary_path" ]; then
        # If not found, check if the downloaded file itself is executable
        if [ -x "${temp_dir}/download" ]; then
            binary_path="${temp_dir}/download"
        else
            echo "  ⚠️  Could not find executable for ${tool_name}"
            return 1
        fi
    fi

    # Copy to install directory
    cp "$binary_path" "${INSTALL_DIR}/${binary_name}"
    chmod +x "${INSTALL_DIR}/${binary_name}"

    return 0
}

# Array of tools to install: (display_name, github_repo, binary_name, asset_pattern)
declare -a TOOLS=(
    "lazygit|jesseduffield/lazygit|lazygit|lazygit.*${OS}.*${BINARY_ARCH}"
    "ripgrep|BurntSushi/ripgrep|rg|ripgrep.*${OS}.*${BINARY_ARCH}.*\\.tar\\.gz"
    "bat|sharkdp/bat|bat|bat.*${OS}.*${BINARY_ARCH}.*\\.tar\\.gz"
    "fd|sharkdp/fd|fd|fd.*${OS}.*${BINARY_ARCH}.*\\.tar\\.gz"
    "fzf|junegunn/fzf|fzf|fzf.*${OS}.*${BINARY_ARCH}"
    "exa|ogham/exa|exa|exa-${OS}-${BINARY_ARCH}"
    "bottom|ClementtsaC/bottom|btm|bottom.*${OS}.*${BINARY_ARCH}.*\\.tar\\.gz"
    "starship|starship/starship|starship|starship-${BINARY_ARCH}-unknown-${OS}"
    "delta|dandavison/delta|delta|delta.*${OS}.*${BINARY_ARCH}.*\\.tar\\.gz"
    "just|casey/just|just|just.*${OS}.*${BINARY_ARCH}"
)

# Filter tools based on OS and skip if already installed with newer version
failed_tools=()
installed_count=0

for tool_spec in "${TOOLS[@]}"; do
    IFS='|' read -r tool_name github_repo binary_name asset_pattern <<< "$tool_spec"

    # Skip if already installed
    if command -v "$binary_name" &> /dev/null; then
        echo -e "${GREEN}✓ ${tool_name} already installed${NC}"
        continue
    fi

    if install_github_binary "$tool_name" "$github_repo" "$binary_name" "$asset_pattern"; then
        installed_count=$((installed_count + 1))
    else
        failed_tools+=("$tool_name")
    fi
done

# Summary
echo ""
echo "═══════════════════════════════════════════════════════════"
echo -e "${GREEN}✓ Installed $installed_count tools${NC}"

if [ ${#failed_tools[@]} -gt 0 ]; then
    echo -e "${RED}✗ Failed to install the following tools:${NC}"
    for tool in "${failed_tools[@]}"; do
        echo -e "  ${RED}• $tool${NC}"
    done
    echo ""
    echo "⚠️  You may need to install these manually or check your internet connection."
fi

echo "═══════════════════════════════════════════════════════════"
echo -e "${GREEN}✅ Modern tools installation complete!${NC}"
echo ""
echo "Make sure ${HOME}/.local/bin is in your PATH:"
echo "  export PATH=\"\${HOME}/.local/bin:\${PATH}\""
